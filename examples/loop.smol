fn main() void {
    let x0: int = 18;
    let y0: int = 6;

    let x: int = x0;
    let y: int = y0;
    while (x != y) {
        if (x > y) {
            x = x - y;
        } else {
            y = y - x;
        }
    }
    print "gcd(";
    print x0;
    print ", ";
    print y0;
    print ") = ";
    println x;
}
